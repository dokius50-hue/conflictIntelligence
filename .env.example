# Supabase (required for app and API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Conflict (default: hormuz_2026)
CONFLICT_ID=hormuz_2026

# Ingestion
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=

# Twitter (optional; scripts/lib/twitter-client.js)
# TWITTER_API_MODE=rapidapi
# RAPIDAPI_KEY=
# or
# TWITTER_BEARER_TOKEN=

# Local API server port (default 3001)
# API_PORT=3001

# Frontend (optional)
# VITE_CONFLICT_ID=hormuz_2026
# VITE_MAPBOX_TOKEN=
